# ============================================================
# CareerPathway — Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# --- App ---
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://careerpathway:password@localhost:5432/careerpathway_db

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Google Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Razorpay (India) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# --- Stripe (International) ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx

# --- SendGrid (Email) ---
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@careerpathway.com

# --- Twilio (SMS/OTP) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# --- Google Cloud Storage ---
GCS_BUCKET_NAME=careerpathway-uploads
GCS_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json (for local dev)

# --- GCP (for CI/CD) ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1
GCP_ARTIFACT_REGISTRY=asia-south1-docker.pkg.dev

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
NEXT_PUBLIC_APP_NAME=CareerPathway
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
